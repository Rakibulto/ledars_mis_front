import { useState } from 'react';
import * as ReactRouter from 'react-router';
import { ArrowLeft, Camera, CheckCircle, XCircle, AlertTriangle, Upload, Trash2, Save } from 'lucide-react';
import { Card, CardHeader, CardBody } from '../../components/ui/card';
import { Button } from '../../components/ui/button';
import { Badge } from '../../components/ui/badge';

const Link = ReactRouter.Link || (ReactRouter as any).default?.Link;
const useNavigate = ReactRouter.useNavigate || (ReactRouter as any).default?.useNavigate;

interface OrderItem {
  id: string;
  description: string;
  specification: string;
  orderedQuantity: number;
  receivedQuantity: number;
  orderedBrand: string;
  receivedBrand: string;
  status: 'match' | 'mismatch' | 'partial' | 'not-received';
  issueNote: string;
  photos: File[];
}

export function CreateGRN() {
  const navigate = useNavigate();
  
  // Basic Info
  const [selectedWO, setSelectedWO] = useState('');
  const [receivingLocation, setReceivingLocation] = useState('');
  const [receiverName, setReceiverName] = useState('');
  const [dateReceived, setDateReceived] = useState('');
  const [timeReceived, setTimeReceived] = useState('');

  // Mock work orders
  const mockWorkOrders = [
    { id: 'WO-2024-001', vendor: 'Premium Office Solutions Ltd', items: 5 },
    { id: 'WO-2024-002', vendor: 'TechSupply Global Inc', items: 5 },
    { id: 'WO-2024-003', vendor: 'MediCare Suppliers', items: 6 }
  ];

  // Mock items from selected WO
  const [items, setItems] = useState<OrderItem[]>([
    {
      id: '1',
      description: 'Ergonomic Executive Desk',
      specification: 'Wooden finish, 1800mm x 900mm',
      orderedQuantity: 25,
      receivedQuantity: 0,
      orderedBrand: 'Herman Miller',
      receivedBrand: '',
      status: 'not-received',
      issueNote: '',
      photos: []
    },
    {
      id: '2',
      description: 'Ergonomic Office Chair',
      specification: 'Mesh back, adjustable armrests',
      orderedQuantity: 50,
      receivedQuantity: 0,
      orderedBrand: 'Steelcase',
      receivedBrand: '',
      status: 'not-received',
      issueNote: '',
      photos: []
    },
    {
      id: '3',
      description: 'Filing Cabinet (4-drawer)',
      specification: 'Steel construction, lockable',
      orderedQuantity: 30,
      receivedQuantity: 0,
      orderedBrand: 'HON',
      receivedBrand: '',
      status: 'not-received',
      issueNote: '',
      photos: []
    }
  ]);

  const handleQuantityChange = (id: string, value: number) => {
    setItems(prev => prev.map(item => {
      if (item.id === id) {
        const received = Math.max(0, Math.min(value, item.orderedQuantity));
        let status: OrderItem['status'] = 'not-received';
        
        if (received === 0) {
          status = 'not-received';
        } else if (received === item.orderedQuantity && item.receivedBrand === item.orderedBrand) {
          status = 'match';
        } else if (received === item.orderedQuantity && item.receivedBrand !== item.orderedBrand) {
          status = 'mismatch';
        } else {
          status = 'partial';
        }
        
        return { ...item, receivedQuantity: received, status };
      }
      return item;
    }));
  };

  const handleBrandChange = (id: string, brand: string) => {
    setItems(prev => prev.map(item => {
      if (item.id === id) {
        const status = brand === item.orderedBrand ? 'match' : 'mismatch';
        return { ...item, receivedBrand: brand, status };
      }
      return item;
    }));
  };

  const handleIssueNoteChange = (id: string, note: string) => {
    setItems(prev => prev.map(item => 
      item.id === id ? { ...item, issueNote: note } : item
    ));
  };

  const handlePhotoUpload = (id: string, files: FileList) => {
    setItems(prev => prev.map(item => {
      if (item.id === id) {
        return { ...item, photos: [...item.photos, ...Array.from(files)] };
      }
      return item;
    }));
  };

  const removePhoto = (itemId: string, photoIndex: number) => {
    setItems(prev => prev.map(item => {
      if (item.id === itemId) {
        return { ...item, photos: item.photos.filter((_, i) => i !== photoIndex) };
      }
      return item;
    }));
  };

  const handleSubmit = () => {
    // Validate
    if (!selectedWO || !receivingLocation || !receiverName || !dateReceived) {
      alert('Please fill in all required fields');
      return;
    }

    const hasReceivedItems = items.some(item => item.receivedQuantity > 0);
    if (!hasReceivedItems) {
      alert('Please receive at least one item');
      return;
    }

    alert('GRN created successfully!');
    navigate('/grn/list');
  };

  const getStatusIcon = (status: OrderItem['status']) => {
    switch (status) {
      case 'match':
        return <CheckCircle className="w-5 h-5 text-success" />;
      case 'mismatch':
        return <AlertTriangle className="w-5 h-5 text-warning" />;
      case 'partial':
        return <AlertTriangle className="w-5 h-5 text-warning" />;
      case 'not-received':
        return <XCircle className="w-5 h-5 text-muted-foreground" />;
    }
  };

  const getStatusBadge = (status: OrderItem['status']) => {
    switch (status) {
      case 'match':
        return <Badge variant="success">Match</Badge>;
      case 'mismatch':
        return <Badge variant="warning">Brand Mismatch</Badge>;
      case 'partial':
        return <Badge variant="warning">Partial</Badge>;
      case 'not-received':
        return <Badge variant="default">Not Received</Badge>;
    }
  };

  const totalOrdered = items.reduce((sum, item) => sum + item.orderedQuantity, 0);
  const totalReceived = items.reduce((sum, item) => sum + item.receivedQuantity, 0);
  const itemsWithIssues = items.filter(item => item.status === 'mismatch' || item.status === 'partial').length;

  return (
    <div className="p-8 max-w-5xl mx-auto">
      {/* Header */}
      <div className="mb-6">
        <div className="flex items-center gap-4 mb-4">
          <Link to="/grn/list">
            <button className="p-2 hover:bg-muted rounded-lg transition-colors">
              <ArrowLeft className="w-5 h-5" />
            </button>
          </Link>
          <div>
            <h1 className="text-2xl font-semibold text-foreground">Create Goods Receive Note</h1>
            <p className="text-muted-foreground">Verify and record delivery from vendor</p>
          </div>
        </div>
      </div>

      {/* Quick Summary Card */}
      <Card className="mb-6 border-primary bg-primary/5">
        <CardBody>
          <div className="grid grid-cols-3 gap-6">
            <div className="text-center">
              <p className="text-sm text-muted-foreground mb-1">Total Ordered</p>
              <p className="text-3xl font-bold text-foreground">{totalOrdered}</p>
            </div>
            <div className="text-center">
              <p className="text-sm text-muted-foreground mb-1">Total Received</p>
              <p className="text-3xl font-bold text-primary">{totalReceived}</p>
            </div>
            <div className="text-center">
              <p className="text-sm text-muted-foreground mb-1">Items with Issues</p>
              <p className={`text-3xl font-bold ${itemsWithIssues > 0 ? 'text-warning' : 'text-success'}`}>
                {itemsWithIssues}
              </p>
            </div>
          </div>
        </CardBody>
      </Card>

      {/* Basic Information */}
      <Card className="mb-6">
        <CardHeader title="Receipt Information" description="Fill in basic details" />
        <CardBody>
          <div className="grid grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-foreground mb-2">
                Select Work Order *
              </label>
              <select
                value={selectedWO}
                onChange={(e) => setSelectedWO(e.target.value)}
                className="w-full px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-base"
              >
                <option value="">Choose a work order</option>
                {mockWorkOrders.map(wo => (
                  <option key={wo.id} value={wo.id}>
                    {wo.id} - {wo.vendor} ({wo.items} items)
                  </option>
                ))}
              </select>
            </div>

            <div>
              <label className="block text-sm font-medium text-foreground mb-2">
                Receiving Location *
              </label>
              <input
                type="text"
                value={receivingLocation}
                onChange={(e) => setReceivingLocation(e.target.value)}
                placeholder="e.g., Main Warehouse, Site A"
                className="w-full px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-base"
              />
            </div>

            <div>
              <label className="block text-sm font-medium text-foreground mb-2">
                Received By (Your Name) *
              </label>
              <input
                type="text"
                value={receiverName}
                onChange={(e) => setReceiverName(e.target.value)}
                placeholder="Enter your full name"
                className="w-full px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-base"
              />
            </div>

            <div className="grid grid-cols-2 gap-2">
              <div>
                <label className="block text-sm font-medium text-foreground mb-2">
                  Date Received *
                </label>
                <input
                  type="date"
                  value={dateReceived}
                  onChange={(e) => setDateReceived(e.target.value)}
                  className="w-full px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-base"
                />
              </div>
              <div>
                <label className="block text-sm font-medium text-foreground mb-2">
                  Time
                </label>
                <input
                  type="time"
                  value={timeReceived}
                  onChange={(e) => setTimeReceived(e.target.value)}
                  className="w-full px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary text-base"
                />
              </div>
            </div>
          </div>
        </CardBody>
      </Card>

      {/* Items Verification */}
      <Card className="mb-6">
        <CardHeader 
          title="Item-by-Item Verification"
          description="Check each item against the work order"
        />
        <CardBody>
          <div className="space-y-6">
            {items.map((item, index) => (
              <div key={item.id} className="border-2 border-border rounded-lg p-4">
                {/* Item Header */}
                <div className="flex items-start justify-between mb-4">
                  <div className="flex items-start gap-3">
                    {getStatusIcon(item.status)}
                    <div>
                      <h3 className="font-semibold text-foreground mb-1">
                        Item {index + 1}: {item.description}
                      </h3>
                      <p className="text-sm text-muted-foreground">{item.specification}</p>
                    </div>
                  </div>
                  {getStatusBadge(item.status)}
                </div>

                {/* Verification Grid */}
                <div className="grid grid-cols-2 gap-4 mb-4">
                  {/* Quantity Comparison */}
                  <div className="p-3 bg-muted/30 rounded-lg">
                    <p className="text-xs font-medium text-muted-foreground mb-2">Quantity Ordered</p>
                    <p className="text-2xl font-bold text-foreground">{item.orderedQuantity}</p>
                  </div>

                  <div className="p-3 bg-primary/5 border-2 border-primary rounded-lg">
                    <label className="text-xs font-medium text-foreground mb-2 block">
                      Quantity Received *
                    </label>
                    <input
                      type="number"
                      value={item.receivedQuantity || ''}
                      onChange={(e) => handleQuantityChange(item.id, parseInt(e.target.value) || 0)}
                      min="0"
                      max={item.orderedQuantity}
                      placeholder="Enter quantity"
                      className="w-full text-2xl font-bold px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                  </div>

                  {/* Brand Comparison */}
                  <div className="p-3 bg-muted/30 rounded-lg">
                    <p className="text-xs font-medium text-muted-foreground mb-2">Brand Ordered</p>
                    <p className="text-lg font-semibold text-foreground">{item.orderedBrand}</p>
                  </div>

                  <div className="p-3 bg-primary/5 border-2 border-primary rounded-lg">
                    <label className="text-xs font-medium text-foreground mb-2 block">
                      Brand Received *
                    </label>
                    <input
                      type="text"
                      value={item.receivedBrand}
                      onChange={(e) => handleBrandChange(item.id, e.target.value)}
                      placeholder="Enter brand/model"
                      className="w-full text-lg font-semibold px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary"
                    />
                  </div>
                </div>

                {/* Issue Notes - Show if there's mismatch */}
                {(item.status === 'mismatch' || item.status === 'partial') && (
                  <div className="mb-4">
                    <label className="block text-sm font-medium text-foreground mb-2">
                      Issue / Mismatch Notes *
                    </label>
                    <textarea
                      value={item.issueNote}
                      onChange={(e) => handleIssueNoteChange(item.id, e.target.value)}
                      placeholder="Describe the issue, mismatch, or reason for partial receipt..."
                      rows={3}
                      className="w-full px-3 py-2 border border-input rounded-lg focus:outline-none focus:ring-2 focus:ring-primary resize-none text-base"
                    />
                  </div>
                )}

                {/* Photo Upload */}
                <div>
                  <label className="block text-sm font-medium text-foreground mb-2">
                    Photos (Optional - Recommended for issues)
                  </label>
                  <div className="space-y-3">
                    <label className="block">
                      <div className="border-2 border-dashed border-border rounded-lg p-4 text-center cursor-pointer hover:border-primary transition-colors">
                        <Camera className="w-8 h-8 text-muted-foreground mx-auto mb-2" />
                        <p className="text-sm font-medium text-foreground mb-1">
                          Tap to take photo or upload
                        </p>
                        <p className="text-xs text-muted-foreground">
                          Take photos of items, packaging, or issues
                        </p>
                      </div>
                      <input
                        type="file"
                        multiple
                        accept="image/*"
                        capture="environment"
                        onChange={(e) => e.target.files && handlePhotoUpload(item.id, e.target.files)}
                        className="hidden"
                      />
                    </label>

                    {item.photos.length > 0 && (
                      <div className="grid grid-cols-4 gap-2">
                        {item.photos.map((photo, photoIndex) => (
                          <div key={photoIndex} className="relative group">
                            <img
                              src={URL.createObjectURL(photo)}
                              alt={`Photo ${photoIndex + 1}`}
                              className="w-full h-24 object-cover rounded-lg"
                            />
                            <button
                              onClick={() => removePhoto(item.id, photoIndex)}
                              className="absolute top-1 right-1 p-1 bg-error text-error-foreground rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
                            >
                              <Trash2 className="w-3 h-3" />
                            </button>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </CardBody>
      </Card>

      {/* Action Buttons */}
      <div className="flex gap-4">
        <Link to="/grn/list" className="flex-1">
          <Button variant="outline" className="w-full">
            Cancel
          </Button>
        </Link>
        <Button variant="primary" className="flex-1" onClick={handleSubmit}>
          <Save className="w-4 h-4 mr-2" />
          Submit GRN
        </Button>
      </div>

      {/* Help Text */}
      <Card className="mt-6 border-warning bg-warning/5">
        <CardBody>
          <div className="flex gap-3">
            <AlertTriangle className="w-5 h-5 text-warning flex-shrink-0 mt-0.5" />
            <div>
              <p className="text-sm font-medium text-foreground mb-1">Important Notes:</p>
              <ul className="text-sm text-muted-foreground space-y-1 list-disc list-inside">
                <li>Verify each item quantity before entering</li>
                <li>Check brand/model matches exactly with order</li>
                <li>Take photos of any damaged or mismatched items</li>
                <li>Add detailed notes for any discrepancies</li>
                <li>Partial receipts are acceptable - remaining items can be received later</li>
              </ul>
            </div>
          </div>
        </CardBody>
      </Card>
    </div>
  );
}

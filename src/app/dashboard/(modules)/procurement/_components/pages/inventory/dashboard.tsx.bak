                        </div>
                        <div className="flex items-center gap-3 text-xs text-muted-foreground">
                          <span>Qty: {item.quantity}</span>
                          <span>•</span>
                          <span>GRN: {item.grnNumber}</span>
                          <span>•</span>
                          <span>{item.location}</span>

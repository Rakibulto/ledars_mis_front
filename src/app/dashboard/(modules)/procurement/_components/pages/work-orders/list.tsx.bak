                      <span>•</span>
                      <span>Vendor: {wo.vendor.name}</span>
                      <span>•</span>
                      <span>Order Date: {wo.orderDate}</span>
                      <span>•</span>
                      <span>Delivery: {wo.deliveryDeadline}</span>
                    </div>
                  </div>

                  <div className="flex gap-2">
                    {wo.status === 'pending-approval' && (
                      <Link to={`/work-orders/${wo.id}/approval`}>
                        <Button variant="warning" size="sm">
                          <CheckCircle className="w-4 h-4 mr-2" />
                          Review
                        </Button>
                      </Link>
                    )}
                    <Link to={`/work-orders/${wo.id}`}>
                      <Button variant="outline" size="sm">
                        <Eye className="w-4 h-4 mr-2" />
                        View Details
                      </Button>
                    </Link>
                    <Link to={`/work-orders/${wo.id}/print`}>
                      <Button variant="outline" size="sm">
                        <Printer className="w-4 h-4 mr-2" />
                        Print
                      </Button>
                    </Link>
                  </div>
                </div>

                <div className="grid grid-cols-4 gap-4 p-3 bg-muted/30 rounded-lg">
                  <div>
                    <p className="text-xs text-muted-foreground mb-1">Total Amount</p>
                    <p className="text-sm font-semibold text-foreground">
                      ${wo.totalAmount.toLocaleString()}
                    </p>
                  </div>
                  <div>
                    <p className="text-xs text-muted-foreground mb-1">Items Progress</p>
                    <p className="text-sm font-medium text-foreground">
                      {wo.deliveredItems}/{wo.items} delivered
                    </p>
                  </div>
                  <div>
                    <p className="text-xs text-muted-foreground mb-1">Payment Status</p>
                    <p className="text-sm font-semibold text-success">
                      ${wo.amountPaid.toLocaleString()} paid
                    </p>
                  </div>
                  <div>
                    <p className="text-xs text-muted-foreground mb-1">Linked Documents</p>
                    <div className="flex items-center gap-2 text-xs">
                      <span className="text-primary">{wo.requisitionNumber}</span>
                      <span>→</span>
                      <span className="text-primary">{wo.awardNumber}</span>
                    </div>
                  </div>
                </div>

                {/* Progress Bar for Delivery */}
                {wo.deliveryStatus === 'in-progress' && (
                  <div className="mt-3">
                    <div className="flex items-center justify-between mb-1">
                      <span className="text-xs text-muted-foreground">Delivery Progress</span>

{
  "name": "@hrm/next-js",
  "author": "Raktch Technology & Software",
  "version": "6.1.0",
  "description": "Next & JavaScript",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3071 --webpack -H 0.0.0.0",
    "start": "next start -p 3072 -H 0.0.0.0",
    "prebuild": "node scripts/generate-manifest.js",
    "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build --webpack",
    "generate-manifest": "node scripts/generate-manifest.js",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "rm:all": "rm -rf node_modules .next out dist build",
    "re:start": "yarn rm:all && yarn install && yarn dev",
    "re:build": "yarn rm:all && yarn install && yarn build",
    "re:build-npm": "npm run rm:all && npm install && npm run build",
    "start:out": "npx serve@latest out -p 3071",
    "icons": "pwa-asset-generator logo.png public/icons -m public/manifest.json -i public/index.html -a '%PUBLIC_URL%'"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "yarn@1.22.22",
